{
  "name": "password_reset",
  "description": "Invalidate old tokens, generate a new one, send the email",
  "version": 1,
  "tasks": [
    {
      "name": "invalidate_old_tokens",
      "taskReferenceName": "cleanup_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "email": "${workflow.input.email}"
      }
    },
    {
      "name": "generate_reset_token",
      "taskReferenceName": "token_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "email": "${workflow.input.email}"
      }
    },
    {
      "name": "send_reset_email",
      "taskReferenceName": "email_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "email": "${token_ref.output.email}",
        "token": "${token_ref.output.token}",
        "expiresAt": "${token_ref.output.expiresAt}"
      }
    }
  ],
  "inputParameters": [
    "email"
  ],
  "outputParameters": {
    "resetUrl": "${email_ref.output.resetUrl}"
  },
  "schemaVersion": 1
}
